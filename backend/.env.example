# Kopiere diese Datei nach .env und fülle alle Werte aus.
# Committe NIEMALS die echte .env Datei.

# =============================================================================
# SERVER
# =============================================================================

# Port auf dem der Backend-Server läuft
PORT=3000

# Umgebung: development | production | test
NODE_ENV=development

# Optionaler Name des Servers (für Logs/Health-Checks)
SERVER_NAME=jn-business-system-api

# Log-Level: error | warn | info | debug
LOG_LEVEL=info

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB Connection String (Atlas oder Self-hosted)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# =============================================================================
# JWT
# =============================================================================

# Geheimer Schlüssel für Access-Token-Signierung (mindestens 32 Zeichen)
# Generieren: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Ablaufzeit des Access-Tokens (z.B. 15m, 1h)
JWT_EXPIRE=15m

# Geheimer Schlüssel für Refresh-Token (anderer Wert als JWT_SECRET)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Schlüssel für datenbankinseitige Verschlüsselung sensibler Felder (32 Bytes hex)
# Generieren: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# =============================================================================
# STRIPE
# =============================================================================

# Stripe Secret Key (sk_test_... für Test, sk_live_... für Production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Signing Secret (aus Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (aus Stripe Dashboard → Products)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id_here
STRIPE_PRICE_STARTER_YEARLY=price_starter_yearly_id_here
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id_here
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id_here
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id_here
STRIPE_PRICE_ENTERPRISE_YEARLY=price_enterprise_yearly_id_here

# =============================================================================
# EMAIL (SMTP)
# =============================================================================

# SMTP-Server (z.B. smtp.gmail.com, smtp.sendgrid.net, mail.example.de)
EMAIL_HOST=smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# SMTP-Port (587 für TLS/STARTTLS, 465 für SSL)
EMAIL_PORT=587
SMTP_PORT=587

# TLS erzwingen: true | false
EMAIL_SECURE=false
SMTP_SECURE=false

# SMTP Login
EMAIL_USER=your_email@example.com
SMTP_USER=your_email@example.com

# SMTP Passwort / App-Passwort
EMAIL_PASS=your_smtp_password_here
EMAIL_PASSWORD=your_smtp_password_here
SMTP_PASS=your_smtp_password_here

# Absender-Adresse in ausgehenden E-Mails
EMAIL_FROM=noreply@jn-business-system.de
SMTP_FROM=noreply@jn-business-system.de

# Support-Adresse (für Benachrichtigungen an interne Mitarbeiter)
SUPPORT_EMAIL=support@jn-business-system.de

# Admin-E-Mails (kommagetrennt, für kritische System-Alerts)
ADMIN_EMAILS=admin@jn-business-system.de

# Adresse für Benachrichtigungen und kritische Alerts
NOTIFICATION_EMAIL=alerts@jn-business-system.de
ALERT_EMAIL=alerts@jn-business-system.de

# =============================================================================
# FRONTEND URLS / CORS
# =============================================================================

# WICHTIG FÜR PRODUCTION:
# FRONTEND_URL=https://app.jn-business-system.de
# PRODUCTION_URL=https://jn-business-system.de
# CORS_ORIGIN=https://app.jn-business-system.de,https://jn-business-system.de
# Ohne diese Werte schlägt CORS im Live-Betrieb fehl!

# URL des Frontends im Development
FRONTEND_URL=http://localhost:5173

# URL des Frontends in Production
PRODUCTION_URL=https://app.jn-business-system.de
PRODUCTION_FRONTEND_URL=https://app.jn-business-system.de

# Zusätzliche CORS-Origin (optional, kommagetrennt)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Öffentliche API-URL (für generierte Links)
API_URL=https://api.jn-business-system.de

# =============================================================================
# REDIS (optional – Fallback auf In-Memory wenn nicht gesetzt)
# =============================================================================

# Redis-Verbindungs-URL (z.B. redis://localhost:6379 oder rediss://... für TLS)
REDIS_URL=redis://localhost:6379

# Alternativ einzeln angeben
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# CEO / ADMIN SECURITY
# =============================================================================

# IP-Whitelist für CEO-Login (kommagetrennt, leer = alle IPs erlaubt)
CEO_IP_WHITELIST=

# Secret für interne Metrics-Endpunkte
METRICS_SECRET=your_metrics_secret_here

# =============================================================================
# SENTRY (optional – Error Monitoring)
# =============================================================================

# DSN aus Sentry Dashboard → Einstellungen → Client Keys (leer = deaktiviert)
SENTRY_DSN=

# Umgebungs-Label in Sentry (z.B. production, staging)
SENTRY_ENVIRONMENT=production

# =============================================================================
# SMS / TWILIO (optional – nur wenn SMS-Benachrichtigungen aktiviert)
# =============================================================================

# SMS-Provider: twilio | messagebird | disabled
SMS_PROVIDER=disabled

# Twilio Account SID (aus Twilio Console)
TWILIO_ACCOUNT_SID=

# Twilio Auth Token
TWILIO_AUTH_TOKEN=

# Twilio Absender-Nummer (E.164-Format, z.B. +4915123456789)
TWILIO_PHONE_NUMBER=

# =============================================================================
# ALERTS / WEBHOOKS (optional)
# =============================================================================

# Slack Incoming Webhook URL für System-Alerts
SLACK_WEBHOOK_URL=

# Discord Webhook URL (Alternative zu Slack)
DISCORD_WEBHOOK_URL=

# =============================================================================
# DSGVO / DATENSCHUTZ
# =============================================================================

# Datenschutzbeauftragter (für automatische DSGVO-E-Mails)
PRIVACY_OFFICER_NAME=Julius Wagenfeldt
PRIVACY_OFFICER_EMAIL=datenschutz@jn-business-system.de
PRIVACY_OFFICER_PHONE=+49 123 456789

# =============================================================================
# RATE LIMITING (optional – Defaults sind im Code gesetzt)
# =============================================================================

# Allgemeines Rate Limit (Requests pro 15min Fenster)
RATE_LIMIT_GENERAL=100

# Auth-spezifisches Limit
RATE_LIMIT_AUTH=20

# Payment-Limit (pro IP)
RATE_LIMIT_PAYMENT=10

# =============================================================================
# BACKUP (optional)
# =============================================================================

# Verzeichnis für lokale Backups
BACKUP_DIR=/var/backups/jn-business-system

# Aufbewahrungsdauer in Tagen
BACKUP_RETENTION_DAYS=30

# Cron-Schedule für automatische Backups (Standard: täglich um 02:00 Uhr)
BACKUP_SCHEDULE=0 2 * * *
